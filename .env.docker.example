# Copy to .env before running docker compose

PORTAL_SECRET_KEY=change-this-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

PORTAL_DB_BACKEND=postgres
PORTAL_POSTGRES_DB=vpnportal
PORTAL_POSTGRES_USER=vpnportal
PORTAL_POSTGRES_PASSWORD=vpnportal
PORTAL_POSTGRES_DSN=postgresql://vpnportal:vpnportal@postgres:5432/vpnportal

VPN_API_TOKEN=change-this-token
VPN_API_URL=
PORTAL_ENABLE_UDP_RELAY=1
VPN_RELAY_PUBLIC_HOST=your-web-public-ip

WG_INTERFACE=wg0
WG_NETWORK=10.7.0.0/24
WG_SERVER_ADDRESS=10.7.0.1
WG_ENDPOINT=your-domain-or-ip:51820
WG_CLIENT_DNS=10.7.0.1
WG_IP_ASSIGNMENT_MODE=dynamic
VPN_ENABLE_WIREGUARD=0
VPN_ENABLE_DNSMASQ=1
VPN_ENABLE_OPENVPN=1
VPN_API_PUBLIC_PORT=8081

OPENVPN_ENABLED=0
OPENVPN_ENDPOINT_HOST=your-domain-or-ip
OPENVPN_ENDPOINT_PORT=1194
OPENVPN_PROTO=tcp
OPENVPN_CLIENT_DNS=10.8.0.1

SHADOWSOCKS_ENABLED=1
SHADOWSOCKS_ENDPOINT_HOST=your-domain-or-ip
SHADOWSOCKS_SERVER_PORT=8388
SHADOWSOCKS_METHOD=chacha20-ietf-poly1305
SHADOWSOCKS_PASSWORD=change-this-password
KCPTUN_ENABLED=1
KCPTUN_SERVER_PORT=29900
KCPTUN_KEY=change-this-kcptun-key

WEB_PUBLIC_PORT=8080
WG_PUBLIC_PORT=51820
OPENVPN_PUBLIC_PORT=1194
DNS_PUBLIC_PORT=5353
WG_RELAY_PORT_START=24000
WG_RELAY_PORT_END=28999
OPENVPN_RELAY_PORT_START=29000
OPENVPN_RELAY_PORT_END=33999
